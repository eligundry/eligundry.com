---
import { getImage } from 'astro:assets'
import { YouTube } from '@astro-community/astro-embed-youtube'
import { fetchOpenGraphData, getYouTubeVideoId } from '../lib/opengraph'

interface Props {
  url: string
}

const { url } = Astro.props
const youtubeId = getYouTubeVideoId(url)
const ogData = youtubeId ? null : await fetchOpenGraphData(url)
const ogImage = ogData?.imageUrl
  ? await getImage({
      src: ogData.imageUrl,
      width: 224,
      format: 'webp',
      quality: 95,
      inferSize: true,
    }).catch(() => null)
  : null
const displayUrl = (() => {
  try {
    return new URL(url).hostname.replace(/^www\./, '')
  } catch {
    return url
  }
})()
---

{
  youtubeId ? (
    <div class="mt-4 mb-6">
      <YouTube id={youtubeId} />
    </div>
  ) : ogData ? (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="not-prose card card-side card-compact bg-base-200 shadow-sm hover:shadow-md transition-shadow no-underline mt-4 mb-6 max-w-md"
      aria-label={`Visit ${ogData.title ?? url}`}
    >
      {ogImage && (
        <figure class="w-20 shrink-0 sm:w-28">
          <img
            src={ogImage.src}
            alt={ogData.title ?? ''}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </figure>
      )}
      <div class="card-body p-3 gap-0.5">
        {ogData.siteName && (
          <p class="text-xs text-base-content/60 m-0">{ogData.siteName}</p>
        )}
        {ogData.title && (
          <h3 class="card-title text-sm m-0 leading-tight">{ogData.title}</h3>
        )}
        {ogData.description && (
          <p class="text-xs text-base-content/80 line-clamp-2 m-0">
            {ogData.description}
          </p>
        )}
        <p class="text-xs text-base-content/50 m-0">{displayUrl}</p>
      </div>
    </a>
  ) : (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="not-prose card card-compact bg-base-200 shadow-sm hover:shadow-md transition-shadow no-underline mt-4 mb-6 max-w-md"
    >
      <div class="card-body p-3">
        <p class="text-sm text-base-content/80 m-0">{displayUrl}</p>
      </div>
    </a>
  )
}
