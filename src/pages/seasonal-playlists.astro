---
import Layout from '../layouts/Layout.astro'
import config from '../config'
---

<Layout
  title="Seasonal Playlists"
  description="Spotify playlists that I have on repeat throughout the seasons."
  fancyBackgroundPoints={10}
>
  <div class:list={['flex', 'flex-col', 'gap-y-4', 'prose', 'paper']}>
    <h1 class="mb-0">Seasonal Playlists</h1>
    <p class="my-0">
      Every season, I put together a playlist of what I'm listening to. Here
      they all are.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        config.spotifyPlaylists.map((id) => (
          <iframe
            title="Spotify seasonal playlist"
            src={`https://open.spotify.com/embed/playlist/${id}?utm_source=generator`}
            allow="encrypted-media"
            width="100%"
            height="380"
            loading="lazy"
          />
        ))
      }
    </div>
  </div>
</Layout>
